<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow / Shadow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#33000000" />
            <size android:width="48dp" android:height="48dp" />
        </shape>
    </item>
    <!-- Main Body Gradient -->
    <item android:bottom="2dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="40dp"
                android:centerX="0.5"
                android:centerY="0.1"
                android:startColor="@color/aero_orb_start"
                android:endColor="@color/aero_orb_end" />
            <stroke android:width="1dp" android:color="#CCFFFFFF" />
        </shape>
    </item>
    <!-- Top Highlight -->
    <item android:top="2dp" android:left="8dp" android:right="8dp" android:bottom="24dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#E6FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
    <!-- Bottom Inner Shadow -->
    <item android:bottom="4dp" android:left="8dp" android:right="8dp" android:top="36dp">
        <shape android:shape="oval">
            <solid android:color="#4D003399" />
        </shape>
    </item>
</layer-list>