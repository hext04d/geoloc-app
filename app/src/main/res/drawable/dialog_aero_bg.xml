<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Background Gradient (Agora com 95% de opacidade para esconder o fundo) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#F2FFFFFF"
                android:endColor="#E6EAF4FF"
                android:type="linear" />
            <corners android:radius="24dp" />
            <stroke android:width="1.5dp" android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Top Highlight (O Brilho Superior) -->
    <item android:bottom="40dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#99FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners
                android:topLeftRadius="24dp"
                android:topRightRadius="24dp" />
        </shape>
    </item>
</layer-list>
