<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">
    <item>
        <layer-list>
            <!-- Shadow -->
            <item android:top="2dp" android:left="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#20000000" />
                    <corners android:radius="24dp" />
                </shape>
            </item>
            <!-- Base Gradient -->
            <item android:bottom="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/forest_primary"
                        android:startColor="@color/forest_light"
                        android:type="linear" />
                    <corners android:radius="24dp" />
                    <stroke android:width="1dp" android:color="#80FFFFFF" />
                </shape>
            </item>
            <!-- Gloss -->
            <item android:bottom="2dp" android:right="2dp" android:top="1dp" android:left="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="#B3FFFFFF"
                        android:centerColor="#00FFFFFF"
                        android:centerY="0.5"
                        android:endColor="#00FFFFFF"
                        android:type="linear" />
                    <corners
                        android:topLeftRadius="24dp"
                        android:topRightRadius="24dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>