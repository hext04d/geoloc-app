<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="@color/forest_primary"
                android:startColor="@color/forest_light"
                android:type="linear" />
            <stroke android:width="1dp" android:color="#80FFFFFF" />
        </shape>
    </item>
    <item android:left="4dp" android:right="4dp" android:top="2dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#B3FFFFFF"
                android:centerColor="#00FFFFFF"
                android:centerY="0.5"
                android:endColor="#00FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>