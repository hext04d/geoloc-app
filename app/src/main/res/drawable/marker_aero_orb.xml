<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow / Shadow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#33000000" />
            <size android:width="32dp" android:height="32dp" />
        </shape>
    </item>
    <!-- Main Body Color (This is what we will tint) -->
    <item android:bottom="2dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="oval">
            <solid android:color="@color/white" />
            <stroke android:width="1dp" android:color="#CCFFFFFF" />
        </shape>
    </item>
    <!-- Inner Shadow (Bottom-ish) -->
    <item android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="16dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="20dp"
                android:centerX="0.5"
                android:centerY="0.8"
                android:startColor="#00000000"
                android:endColor="#66000000" />
        </shape>
    </item>
    <!-- Top Highlight Gloss -->
    <item android:top="2dp" android:left="6dp" android:right="6dp" android:bottom="16dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#E6FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>