<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    tools:context=".MainActivity">

    <!-- Mapa ocupa o fundo todo -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Botão de Configurações (Canto Superior Esquerdo) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_gravity="top|start"
        android:contentDescription="Configurações"
        app:srcCompat="@android:drawable/ic_menu_preferences"
        app:tint="?attr/colorOnSurfaceVariant"
        app:backgroundTint="?attr/colorSurface"
        app:elevation="0dp"
        app:pressedTranslationZ="0dp" />

    <!-- Botões Superiores Direitos -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="top|end"
        android:layout_margin="16dp">

        <!-- Botão de Polígono -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnTogglePolygon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:contentDescription="Mostrar Polígono"
            app:srcCompat="@android:drawable/ic_menu_share"
            app:tint="?attr/colorOnSurfaceVariant"
            app:backgroundTint="?attr/colorSurface"
            app:elevation="0dp"
            app:pressedTranslationZ="0dp" />

        <!-- Botão de Centralizar -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabCenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Centralizar Localização"
            app:srcCompat="@android:drawable/ic_menu_mylocation"
            app:tint="?attr/colorOnPrimaryContainer"
            app:backgroundTint="?attr/colorPrimaryContainer"
            app:elevation="0dp"
            app:pressedTranslationZ="0dp" />
    </LinearLayout>

    <!-- Gaveta (Bottom Sheet) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:behavior_hideable="false"
        app:behavior_peekHeight="220dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Alça superior -->
            <View
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:background="?attr/colorOutlineVariant" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="40dp">

                    <TextView
                        android:id="@+id/tvAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Carregando endereço..."
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tvLatitude"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Lat: ---"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurfaceVariant"/>

                        <TextView
                            android:id="@+id/tvAltitude"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Alt: ---"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAccuracy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Precisão: ---"
                        android:textSize="14sp"
                        android:textColor="?attr/colorPrimary"/>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Aguardando sinal..."
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>

                    <!-- Botões: Alinhamento e tamanho corrigidos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btnSaveLocation"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="Salvar Localização" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnToggleEditMode"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="12dp"
                            android:padding="0dp"
                            app:icon="@android:drawable/ic_menu_preferences"
                            app:iconSize="24dp"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:insetLeft="0dp"
                            android:insetRight="0dp"
                            android:contentDescription="Modo de Edição" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Localizações Salvas"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="?attr/colorOnSurface" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSavedLocations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_saved_location" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>