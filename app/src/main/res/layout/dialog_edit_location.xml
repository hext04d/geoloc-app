<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_aero_bg">

    <!-- Alça (Drag Handle) conforme o HTML -->
    <View
        android:layout_width="40dp"
        android:layout_height="6dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/drag_handle_aero" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Título com Sombra Brilhante -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_loc_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/aero_text_dark"
                android:layout_marginBottom="20dp"
                android:shadowColor="#CCFFFFFF"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="1" />

            <!-- Campo Apelido -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nickname_label"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/aero_text_blue"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="4dp"
                android:shadowColor="#B3FFFFFF"
                android:shadowDy="1"
                android:shadowRadius="1"/>

            <EditText
                android:id="@+id/etNickname"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/nickname_hint"
                android:background="@drawable/glossy_edittext_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp"
                android:inputType="textCapSentences"
                android:textColor="@color/aero_text_dark"
                android:textSize="16sp"
                android:textColorHint="#7799bb"/>

            <!-- Campo Endereço -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/address_label"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/aero_text_blue"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="4dp"
                android:shadowColor="#B3FFFFFF"
                android:shadowDy="1"
                android:shadowRadius="1"/>

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:gravity="top"
                android:background="@drawable/glossy_edittext_bg"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:inputType="textMultiLine"
                android:textColor="@color/aero_text_dark"
                android:textSize="14sp" />

            <!-- Row Latitude e Longitude -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/latitude_label"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/aero_text_blue"
                        android:layout_marginBottom="4dp"
                        android:shadowColor="#B3FFFFFF"
                        android:shadowDy="1"
                        android:shadowRadius="1"/>
                    <EditText
                        android:id="@+id/etLatitude"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/glossy_edittext_bg"
                        android:paddingHorizontal="12dp"
                        android:inputType="numberSigned|numberDecimal"
                        android:textColor="@color/aero_text_dark" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/longitude_label"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/aero_text_blue"
                        android:layout_marginBottom="4dp"
                        android:shadowColor="#B3FFFFFF"
                        android:shadowDy="1"
                        android:shadowRadius="1"/>
                    <EditText
                        android:id="@+id/etLongitude"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/glossy_edittext_bg"
                        android:paddingHorizontal="12dp"
                        android:inputType="numberSigned|numberDecimal"
                        android:textColor="@color/aero_text_dark" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/marker_color_label"
                android:textStyle="bold"
                android:textColor="@color/aero_text_dark"
                android:layout_marginBottom="12dp"
                android:shadowColor="#B3FFFFFF"
                android:shadowDy="1"
                android:shadowRadius="1" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never">

                <RadioGroup
                    android:id="@+id/rgColors"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <RadioButton
                        android:id="@+id/rbColorPink"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:button="@null"
                        android:background="@drawable/orb_aero_bg"
                        android:backgroundTint="@color/aero_marker_pink"
                        android:layout_marginEnd="10dp" />

                    <RadioButton
                        android:id="@+id/rbColorBlue"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:button="@null"
                        android:background="@drawable/orb_aero_bg"
                        android:backgroundTint="@color/aero_marker_blue"
                        android:layout_marginEnd="10dp" />

                    <RadioButton
                        android:id="@+id/rbColorGreen"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:button="@null"
                        android:background="@drawable/orb_aero_bg"
                        android:backgroundTint="@color/aero_marker_green"
                        android:layout_marginEnd="10dp" />

                    <RadioButton
                        android:id="@+id/rbColorOrange"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:button="@null"
                        android:background="@drawable/orb_aero_bg"
                        android:backgroundTint="@color/aero_marker_orange"
                        android:layout_marginEnd="10dp" />

                    <RadioButton
                        android:id="@+id/rbColorPurple"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:button="@null"
                        android:background="@drawable/orb_aero_bg"
                        android:backgroundTint="@color/aero_marker_purple"
                        android:layout_marginEnd="10dp" />

                    <RadioButton
                        android:id="@+id/rbColorRed"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:button="@null"
                        android:background="@drawable/orb_aero_bg"
                        android:backgroundTint="@color/aero_marker_red"
                        android:layout_marginEnd="10dp" />

                </RadioGroup>
            </HorizontalScrollView>
            
            <!-- Botões Customizados Aero -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="8dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCancelEdit"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/btn_cancel"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:background="@drawable/glossy_blue_button_bg" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSaveEdit"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/btn_save"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:background="@drawable/glossy_green_button_bg" />
            </LinearLayout>
            
        </LinearLayout>
    </ScrollView>
</LinearLayout>